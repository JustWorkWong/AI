{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "bff": {
        "ClusterId": "ops-bff",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ops-bff": {
        "Destinations": {
          "default": {
            "Address": "http://ops-bff"
          }
        }
      }
    }
  }
}
